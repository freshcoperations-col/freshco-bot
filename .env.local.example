# WhatsApp Cloud API (Meta)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Supabase (server-side) — productos, órdenes, mensajes
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (browser/dashboard - mismas llaves que arriba)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claude AI (Anthropic) — modelo: claude-haiku-4-5
CLAUDE_API_KEY=

# Notificaciones push al celular del asesor (app ntfy — gratis, sin registro)
# Pon un nombre único y secreto, ej: freshco-alertas-2024
NTFY_TOPIC=

# URL pública de la tienda — usada para generar links en mensajes del bot
WEBPAGE_BASE_URL=https://freshco-design.com

# ─── Wompi (pasarela de pagos Colombia) ──────────────────────────────────────
# Sacar todas las llaves desde: https://comercios.wompi.co
# En modo prueba: las llaves empiezan por "pub_test_" y "test_integrity_".

# Llave pública — se incluye en la URL del checkout (puede ser visible).
WOMPI_PUBLIC_KEY=pub_test_

# Secret de integridad — para firmar la URL del checkout. NO compartir.
WOMPI_INTEGRITY_SECRET=test_integrity_

# Secret de eventos — para validar la firma de los webhooks. NO compartir.
# Configurar en el dashboard de Wompi → Eventos → Crear endpoint.
WOMPI_EVENTS_SECRET=

# URL a la que Wompi redirige al cliente tras pagar (página de gracias).
WOMPI_REDIRECT_URL=https://freshco-design.com/checkout/gracias

# Solo para desarrollo local: si está en "1" saltea la validación de firma
# del webhook. NUNCA dejar en "1" en producción.
WOMPI_SKIP_SIGNATURE=
